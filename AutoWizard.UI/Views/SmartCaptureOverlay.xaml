<Window x:Class="AutoWizard.UI.Views.SmartCaptureOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SmartCaptureOverlay" 
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowState="Maximized" Topmost="True"
        ShowInTaskbar="False"
        Cursor="Cross">
    <Grid>
        <!-- Background Image (Opaque, Freeze Screen) -->
        <Image x:Name="BackgroundImage" Stretch="Fill"/>
        
        <!-- Dimming Layer (Visual "Hole" for selection) -->
        <Path x:Name="DimmingLayer" Fill="#A0000000" IsHitTestVisible="False"/>

        <!-- Selection Layer -->
        <Canvas x:Name="SelectionCanvas" Background="Transparent"
                MouseDown="OnMouseDown" MouseMove="OnMouseMove" MouseUp="OnMouseUp">
            
            <!-- Selection Rectangle Border -->
            <Rectangle x:Name="SelectionRect" 
                       Stroke="#00FF00" StrokeThickness="2"
                       Fill="Transparent"
                       Visibility="Collapsed"/>

            <!-- Color Picker Magnifier (only visible in color picker mode) -->
            <Border x:Name="MagnifierPanel" Visibility="Collapsed"
                    Width="160" Height="160"
                    BorderBrush="#AAFFFFFF" BorderThickness="1"
                    CornerRadius="6"
                    IsHitTestVisible="False">
                <Border.Effect>
                    <DropShadowEffect Color="Black" Opacity="0.5" BlurRadius="8" ShadowDepth="2"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="32"/>
                    </Grid.RowDefinitions>
                    <!-- Pixel Grid with nearest-neighbor scaling for accurate magnification -->
                    <Image x:Name="MagnifierImage" Grid.Row="0" Stretch="Fill" RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                    <!-- Center Crosshair -->
                    <Canvas Grid.Row="0" IsHitTestVisible="False">
                        <Line X1="64" Y1="0" X2="64" Y2="128" Stroke="#80FFFFFF" StrokeThickness="1"/>
                        <Line X1="0" Y1="64" X2="128" Y2="64" Stroke="#80FFFFFF" StrokeThickness="1"/>
                    </Canvas>
                    <!-- Color Info Bar -->
                    <Border Grid.Row="1" Background="#222222" Padding="6,4">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Border x:Name="ColorSwatch" Width="20" Height="20" CornerRadius="3" BorderBrush="#555" BorderThickness="1" Margin="0,0,8,0"/>
                            <TextBlock x:Name="ColorHexLabel" Foreground="White" FontSize="12" FontFamily="Consolas" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Canvas>

        <!-- Hint Text -->
        <Border HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,50,0,0"
                Background="#80000000" Padding="10,5" CornerRadius="5">
            <TextBlock x:Name="HintText" Text="請拖曳滑鼠框選區域 (按 Esc 取消)" Foreground="White" FontSize="16"/>
        </Border>
    </Grid>
</Window>
