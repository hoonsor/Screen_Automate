<Window x:Class="AutoWizard.UI.Views.RecordingToolbar"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AutoWizard 錄製"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="Manual"
        ResizeMode="NoResize"
        WindowStyle="None"
        Topmost="True"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False">
    <Border Background="#F01A1A2E" CornerRadius="12" Padding="14,8" Margin="4"
            BorderBrush="#44FFFFFF" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.5" Color="#000000"/>
        </Border.Effect>
        <StackPanel Orientation="Horizontal">
            <!-- 錄製紅點閃爍 -->
            <Ellipse Width="12" Height="12" Fill="#FF4444" Margin="0,0,10,0" VerticalAlignment="Center">
                <Ellipse.Triggers>
                    <EventTrigger RoutedEvent="Loaded">
                        <BeginStoryboard>
                            <Storyboard RepeatBehavior="Forever">
                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                               From="1.0" To="0.2" Duration="0:0:0.8"
                                               AutoReverse="True"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Ellipse.Triggers>
            </Ellipse>

            <!-- 狀態文字 -->
            <TextBlock x:Name="StatusText" Text="錄製中" 
                      Foreground="White" FontSize="13" FontWeight="Bold"
                      VerticalAlignment="Center" Margin="0,0,12,0"/>

            <!-- 計時器 -->
            <TextBlock x:Name="TimerText" Text="00:00" 
                      Foreground="#AAAAAA" FontSize="12" FontFamily="Consolas"
                      VerticalAlignment="Center" Margin="0,0,14,0"/>

            <!-- 分隔線 -->
            <Rectangle Width="1" Height="20" Fill="#44FFFFFF" Margin="0,0,14,0"/>

            <!-- 停止按鈕 -->
            <Button x:Name="StopButton" Click="StopButton_Click"
                    Cursor="Hand" ToolTip="停止錄製 (F9)">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="StopBd" Background="#CC3333" CornerRadius="6" 
                                Padding="10,5" BorderBrush="#FF5555" BorderThickness="1">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⏹" FontSize="12" Foreground="White" 
                                           Margin="0,0,5,0" VerticalAlignment="Center"/>
                                <TextBlock Text="停止 (F9)" FontSize="11" Foreground="White" 
                                           FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="StopBd" Property="Background" Value="#FF4444"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="StopBd" Property="Background" Value="#AA2222"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- 分隔線 -->
            <Rectangle Width="1" Height="20" Fill="#44FFFFFF" Margin="14,0,14,0"/>

            <!-- 截圖按鈕 -->
            <Button x:Name="ScreenshotButton" Click="ScreenshotButton_Click"
                    Cursor="Hand" ToolTip="即時截圖 (ScrollLock)">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ShotBd" Background="#2196F3" CornerRadius="6" 
                                Padding="10,5" BorderBrush="#64B5F6" BorderThickness="1">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📷" FontSize="12" Foreground="White" 
                                           Margin="0,0,5,0" VerticalAlignment="Center"/>
                                <TextBlock Text="截圖 (ScrollLock)" FontSize="11" Foreground="White" 
                                           FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ShotBd" Property="Background" Value="#42A5F5"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ShotBd" Property="Background" Value="#1976D2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>
    </Border>
</Window>
