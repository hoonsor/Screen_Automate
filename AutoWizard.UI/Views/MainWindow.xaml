<Window x:Class="AutoWizard.UI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:prism="http://prismlibrary.com/"
        xmlns:local="clr-namespace:AutoWizard.UI.Views"
        xmlns:controls="clr-namespace:AutoWizard.UI.Controls"
        xmlns:converters="clr-namespace:AutoWizard.UI.Converters"
        prism:ViewModelLocator.AutoWireViewModel="True"
        Title="{Binding Title}" Height="700" Width="1100"
        WindowStartupLocation="CenterScreen">

    <!-- Keyboard Shortcuts -->
    <Window.InputBindings>
        <KeyBinding Gesture="Ctrl+N" Command="{Binding NewScriptCommand}"/>
        <KeyBinding Gesture="Ctrl+O" Command="{Binding OpenScriptCommand}"/>
        <KeyBinding Gesture="Ctrl+S" Command="{Binding SaveScriptCommand}"/>
        <KeyBinding Gesture="Ctrl+Shift+S" Command="{Binding SaveScriptAsCommand}"/>
        
        <KeyBinding Gesture="Ctrl+F9" Command="{Binding RecordCommand}"/>
        <KeyBinding Gesture="Ctrl+F10" Command="{Binding ToggleRunCommand}"/>
        <!-- ScrollLock 由全域鉤子曬截，不需要 WPF InputBinding -->
        
        <KeyBinding Gesture="Ctrl+Z" Command="{Binding EditorViewModel.UndoCommand}"/>
        <KeyBinding Gesture="Ctrl+Shift+Z" Command="{Binding EditorViewModel.RedoCommand}"/>
        <KeyBinding Gesture="Ctrl+X" Command="{Binding EditorViewModel.CutCommand}"/>
        <KeyBinding Gesture="Ctrl+C" Command="{Binding EditorViewModel.CopyCommand}"/>
        <KeyBinding Gesture="Ctrl+V" Command="{Binding EditorViewModel.PasteCommand}"/>
        <KeyBinding Key="Delete" Command="{Binding EditorViewModel.DeleteActionCommand}"/>
    </Window.InputBindings>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <converters:IndexConverter x:Key="IndexConverter"/>
        <converters:ItemIndexConverter x:Key="ItemIndexConverter"/>
        <converters:BoolToStatusTextConverter x:Key="BoolToStatusTextConverter"/>
        
        <!-- 工具箱按鈕樣式 -->
        <Style x:Key="ToolboxButton" TargetType="Button">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Background" Value="#FAFAFA"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E3F2FD"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#90CAF9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#BBDEFB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 編輯器 ListBox 選取樣式 -->
        <Style x:Key="ActionListBoxItem" TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" 
                                BorderThickness="0" BorderBrush="Transparent" Padding="0">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#BBDEFB"/>
                                <Setter TargetName="Bd" Property="BorderThickness" Value="3,0,0,0"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#1976D2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Menu Bar -->
        <Menu Grid.Row="0">
            <MenuItem Header="檔案(_F)">
                <MenuItem Header="新增腳本(_N)" Command="{Binding NewScriptCommand}"/>
                <MenuItem Header="開啟腳本(_O)" Command="{Binding OpenScriptCommand}"/>
                <MenuItem Header="儲存腳本(_S)" Command="{Binding SaveScriptCommand}"/>
                <Separator/>
                <MenuItem Header="結束(_X)" Click="OnExit"/>
            </MenuItem>
            <MenuItem Header="編輯(_E)">
                <MenuItem Header="復原(_U)" Command="{Binding EditorViewModel.UndoCommand}" InputGestureText="Ctrl+Z"/>
                <MenuItem Header="重做(_R)" Command="{Binding EditorViewModel.RedoCommand}" InputGestureText="Ctrl+Shift+Z"/>
                <Separator/>
                <MenuItem Header="剪下(_T)" Command="{Binding EditorViewModel.CutCommand}" InputGestureText="Ctrl+X"/>
                <MenuItem Header="複製(_C)" Command="{Binding EditorViewModel.CopyCommand}" InputGestureText="Ctrl+C"/>
                <MenuItem Header="貼上(_P)" Command="{Binding EditorViewModel.PasteCommand}" InputGestureText="Ctrl+V"/>
                <Separator/>
                <MenuItem Header="刪除(_D)" Command="{Binding EditorViewModel.DeleteActionCommand}" InputGestureText="Delete"/>
            </MenuItem>
            <MenuItem Header="執行(_R)">
                <MenuItem Header="執行腳本(_R)" Command="{Binding RunScriptCommand}"/>
                <MenuItem Header="停止執行(_S)" Command="{Binding StopScriptCommand}"/>
                <Separator/>
                <MenuItem Header="開始錄製(_R)" Command="{Binding RecordCommand}"/>
            </MenuItem>
            <MenuItem Header="說明(_H)">
                <MenuItem Header="關於(_A)"/>
            </MenuItem>
        </Menu>

        <!-- Toolbar -->
        <ToolBar Grid.Row="1">
            <Button Command="{Binding NewScriptCommand}" ToolTip="新增腳本">
                <TextBlock Text="📄" FontSize="16"/>
            </Button>
            <Button Command="{Binding OpenScriptCommand}" ToolTip="開啟腳本">
                <TextBlock Text="📂" FontSize="16"/>
            </Button>
            <Button Command="{Binding SaveScriptCommand}" ToolTip="儲存腳本">
                <TextBlock Text="💾" FontSize="16"/>
            </Button>
            <Separator/>
            <Button Command="{Binding RunScriptCommand}" ToolTip="執行腳本">
                <TextBlock Text="▶️" FontSize="16"/>
            </Button>
            <Button Command="{Binding StopScriptCommand}" ToolTip="停止執行">
                <TextBlock Text="⏹️" FontSize="16"/>
            </Button>
            <Separator/>
            <Button Command="{Binding RecordCommand}" ToolTip="開始錄製 (Ctrl+F9)">
                <TextBlock Text="⏺️" FontSize="16"/>
            </Button>
            <Separator/>
            <Button Command="{Binding SmartCaptureCommand}" ToolTip="智慧截圖 (ScrollLock)">
                <TextBlock Text="📸" FontSize="16"/>
            </Button>
            <Separator/>
            
            <!-- Status Indicator -->
            <Border Width="16" Height="16" CornerRadius="8" Margin="4,0" BorderBrush="#999" BorderThickness="1"
                    ToolTip="{Binding EditorViewModel.IsDirty, Converter={StaticResource BoolToStatusTextConverter}}">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="#4CAF50"/> <!-- Saved (Green) -->
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding EditorViewModel.IsDirty}" Value="True">
                                <Setter Property="Background" Value="#F44336"/> <!-- Dirty (Red) -->
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
            </Border>
            <Button Command="{Binding PickColorCommand}" ToolTip="色彩選擇器">
                <TextBlock Text="🎨" FontSize="16"/>
            </Button>
        </ToolBar>

        <!-- Main Content Area -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="260"/>
            </Grid.ColumnDefinitions>

            <!-- Toolbox -->
            <Border Grid.Column="0" BorderBrush="#E0E0E0" BorderThickness="0,0,1,0" Padding="8">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="🧰 指令工具箱" FontWeight="Bold" FontSize="13" Margin="0,0,0,10"/>
                        
                        <!-- 輸入指令 -->
                        <Expander IsExpanded="True" Margin="0,0,0,6">
                            <Expander.Header>
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="8" Height="8" Fill="#4CAF50" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="輸入指令" FontWeight="SemiBold" FontSize="12"/>
                                </StackPanel>
                            </Expander.Header>
                            <StackPanel Margin="14,4,0,0">
                                <Button Style="{StaticResource ToolboxButton}"
                                        Command="{Binding AddActionCommand}" CommandParameter="Click">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🖱️" Margin="0,0,6,0"/>
                                        <TextBlock Text="點擊"/>
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource ToolboxButton}"
                                        Command="{Binding AddActionCommand}" CommandParameter="MouseDown">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🔽" Margin="0,0,6,0"/>
                                        <TextBlock Text="按下"/>
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource ToolboxButton}"
                                        Command="{Binding AddActionCommand}" CommandParameter="MouseUp">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🔼" Margin="0,0,6,0"/>
                                        <TextBlock Text="放開"/>
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource ToolboxButton}"
                                        Command="{Binding AddActionCommand}" CommandParameter="Type">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="⌨️" Margin="0,0,6,0"/>
                                        <TextBlock Text="輸入文字"/>
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource ToolboxButton}"
                                        Command="{Binding AddActionCommand}" CommandParameter="Keyboard">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🎹" Margin="0,0,6,0"/>
                                        <TextBlock Text="快捷鍵"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Expander>
                        
                        <!-- 控制流指令 -->
                        <Expander IsExpanded="True" Margin="0,0,0,6">
                            <Expander.Header>
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="8" Height="8" Fill="#FF9800" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="控制流" FontWeight="SemiBold" FontSize="12"/>
                                </StackPanel>
                            </Expander.Header>
                            <StackPanel Margin="14,4,0,0">
                                <Button Style="{StaticResource ToolboxButton}"
                                        Command="{Binding AddActionCommand}" CommandParameter="If">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🔀" Margin="0,0,6,0"/>
                                        <TextBlock Text="條件判斷"/>
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource ToolboxButton}"
                                        Command="{Binding AddActionCommand}" CommandParameter="Loop">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🔁" Margin="0,0,6,0"/>
                                        <TextBlock Text="迴圈"/>
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource ToolboxButton}"
                                        Command="{Binding AddActionCommand}" CommandParameter="SetVariable">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="📌" Margin="0,0,6,0"/>
                                        <TextBlock Text="設定變數"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Expander>
                        
                        <!-- 視覺辨識指令 -->
                        <Expander IsExpanded="True" Margin="0,0,0,6">
                            <Expander.Header>
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="8" Height="8" Fill="#2196F3" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="視覺辨識" FontWeight="SemiBold" FontSize="12"/>
                                </StackPanel>
                            </Expander.Header>
                            <StackPanel Margin="14,4,0,0">
                                <Button Style="{StaticResource ToolboxButton}"
                                        Command="{Binding AddActionCommand}" CommandParameter="FindImage">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🔍" Margin="0,0,6,0"/>
                                        <TextBlock Text="尋找影像"/>
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource ToolboxButton}"
                                        Command="{Binding AddActionCommand}" CommandParameter="OCR">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="📝" Margin="0,0,6,0"/>
                                        <TextBlock Text="OCR 辨識"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Expander>

                        <!-- 工具指令 -->
                        <Expander IsExpanded="True" Margin="0,0,0,6">
                            <Expander.Header>
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="8" Height="8" Fill="#9C27B0" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="工具" FontWeight="SemiBold" FontSize="12"/>
                                </StackPanel>
                            </Expander.Header>
                            <StackPanel Margin="14,4,0,0">
                                <Button Style="{StaticResource ToolboxButton}"
                                        Command="{Binding AddActionCommand}" CommandParameter="Wait">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="⏳" Margin="0,0,6,0"/>
                                        <TextBlock Text="等待"/>
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource ToolboxButton}"
                                        Command="{Binding AddActionCommand}" CommandParameter="Screenshot">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="📷" Margin="0,0,6,0"/>
                                        <TextBlock Text="螢幕截圖"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Expander>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"/>

            <!-- Script Editor -->
            <Border Grid.Column="2" Background="#F5F5F5">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- 編輯器標題 -->
                    <Border Grid.Row="0" Background="#FAFAFA" Padding="8,6" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
                        <Grid>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                <TextBlock Text="📋" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding EditorViewModel.ScriptName}" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center"/>
                                <TextBlock Text=" •" FontWeight="Bold" FontSize="14" VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#4CAF50"/> <!-- Default Green -->
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding EditorViewModel.IsDirty}" Value="True">
                                                    <Setter Property="Foreground" Value="#FF5722"/> <!-- Red when Dirty -->
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock Text="{Binding EditorViewModel.Actions.Count, StringFormat='  ({0} 個指令)'}" 
                                           Foreground="#9E9E9E" FontSize="11" VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </StackPanel>
                            
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <ToggleButton IsChecked="{Binding EditorViewModel.IsCodeViewMode}"
                                              Padding="6,2" Background="Transparent" BorderThickness="0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="💻" Margin="0,0,4,0"/>
                                        <TextBlock Text="程式碼模式"/>
                                    </StackPanel>
                                </ToggleButton>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- 指令列表 -->
                    <!-- 指令列表 (Visual View) -->
                    <ListBox Grid.Row="1" 
                             x:Name="ActionListBox"
                             ItemsSource="{Binding EditorViewModel.FlattenedNodes}"
                             SelectedItem="{Binding EditorViewModel.SelectedNode, Mode=TwoWay}"
                             SelectionMode="Extended"
                             SelectionChanged="ActionListBox_SelectionChanged"
                             ItemContainerStyle="{StaticResource ActionListBoxItem}"
                             Background="Transparent" BorderThickness="0"
                             VirtualizingStackPanel.IsVirtualizing="True"
                             VirtualizingStackPanel.VirtualizationMode="Recycling"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             AlternationCount="2147483647">
                        <ListBox.Style>
                            <Style TargetType="ListBox">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding EditorViewModel.IsCodeViewMode}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.Style>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <!-- Visual Index -->
                                    <Border Grid.Column="0" Background="#EEEEEE" Width="24" Margin="0,0,0,0"
                                            VerticalAlignment="Stretch" BorderBrush="#DDDDDD" BorderThickness="0,0,1,0">
                                        <TextBlock Text="{Binding ., Converter={StaticResource ItemIndexConverter}, ConverterParameter={x:Reference ActionListBox}}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   Foreground="#999999" FontSize="11" FontWeight="Bold"/>
                                    </Border>

                                    <controls:ActionBlockControl Grid.Column="1"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- DSL Code Editor Area -->
                    <Grid Grid.Row="1">
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding EditorViewModel.IsCodeViewMode}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" MinWidth="40"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Line Numbers Gutter -->
                        <ListBox Grid.Column="0" 
                                 ItemsSource="{Binding EditorViewModel.CodeLines}"
                                 Background="#F0F0F0" BorderThickness="0,0,1,0" BorderBrush="#E0E0E0"
                                 ScrollViewer.VerticalScrollBarVisibility="Hidden"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 Padding="0,8,4,0" IsHitTestVisible="False"
                                 x:Name="LineNumberList">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Focusable" Value="False"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border Background="{TemplateBinding Background}" Padding="4,0">
                                                    <ContentPresenter/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding LineNumber}" 
                                               Foreground="#999999" 
                                               FontSize="14" 
                                               FontFamily="Consolas" 
                                               HorizontalAlignment="Right"
                                               Height="19.5"/> <!-- Adjust Height to match font size -->
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <!-- JSON Editor (Code View) -->
                        <TextBox Grid.Column="1"
                                 x:Name="CodeEditor"
                                 Text="{Binding EditorViewModel.JsonSource, UpdateSourceTrigger=LostFocus}"
                                 AcceptsReturn="True"
                                 AcceptsTab="True"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 FontFamily="Consolas"
                                 FontSize="14"
                                 Padding="8"
                                 BorderThickness="0"
                                 Background="#FAFAFA"
                                 ScrollViewer.ScrollChanged="CodeEditor_ScrollChanged"
                                 TextChanged="CodeEditor_TextChanged"/>
                    </Grid>

                    <!-- 空狀態提示 -->
                    <TextBlock Grid.Row="1" 
                               Text="從左側工具箱點擊指令以新增到腳本中"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Foreground="#BDBDBD" FontSize="14">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding EditorViewModel.Actions.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!-- 編輯器工具列 -->
                    <Border Grid.Row="2" Background="#FAFAFA" Padding="6,4" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0">
                        <Grid>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                <Button x:Name="AddChildButton" Content="➕ 子指令 ▾" ToolTip="將指令新增至選取的容器中"
                                        IsEnabled="{Binding EditorViewModel.AddChildCommand.CanExecute}"
                                        Padding="8,2" Margin="2,0" FontSize="11"
                                        Click="AddChildButton_Click">
                                    <Button.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="🖱️ 點擊" Command="{Binding AddChildActionCommand}" CommandParameter="Click"/>
                                            <MenuItem Header="⌨️ 輸入文字" Command="{Binding AddChildActionCommand}" CommandParameter="Type"/>
                                            <MenuItem Header="⌨️ 快捷鍵" Command="{Binding AddChildActionCommand}" CommandParameter="Keyboard"/>
                                            <Separator/>
                                            <MenuItem Header="🔀 條件判斷" Command="{Binding AddChildActionCommand}" CommandParameter="If"/>
                                            <MenuItem Header="🔁 迴圈" Command="{Binding AddChildActionCommand}" CommandParameter="Loop"/>
                                            <Separator/>
                                            <MenuItem Header="⏳ 等待" Command="{Binding AddChildActionCommand}" CommandParameter="Wait"/>
                                            <MenuItem Header="📌 設定變數" Command="{Binding AddChildActionCommand}" CommandParameter="SetVariable"/>
                                            <Separator/>
                                            <MenuItem Header="🔍 尋找影像" Command="{Binding AddChildActionCommand}" CommandParameter="FindImage"/>
                                            <MenuItem Header="📝 OCR 辨識" Command="{Binding AddChildActionCommand}" CommandParameter="OCR"/>
                                            <MenuItem Header="📷 螢幕截圖" Command="{Binding AddChildActionCommand}" CommandParameter="Screenshot"/>
                                        </ContextMenu>
                                    </Button.ContextMenu>
                                </Button>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="↩" ToolTip="復原 (Ctrl+Z)"
                                        Command="{Binding EditorViewModel.UndoCommand}"
                                        Padding="8,2" Margin="2,0" FontSize="12"/>
                                <Button Content="↪" ToolTip="重做 (Ctrl+Shift+Z)"
                                        Command="{Binding EditorViewModel.RedoCommand}"
                                        Padding="8,2" Margin="2,0" FontSize="12"/>
                                <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="4,2"/>
                                <Button Content="✂" ToolTip="剪下 (Ctrl+X)"
                                        Command="{Binding EditorViewModel.CutCommand}"
                                        Padding="8,2" Margin="2,0" FontSize="12"/>
                                <Button Content="📋" ToolTip="複製 (Ctrl+C)"
                                        Command="{Binding EditorViewModel.CopyCommand}"
                                        Padding="8,2" Margin="2,0" FontSize="12"/>
                                <Button Content="📂" ToolTip="貼上 (Ctrl+V)"
                                        Command="{Binding EditorViewModel.PasteCommand}"
                                        Padding="8,2" Margin="2,0" FontSize="12"/>
                                <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="4,2"/>
                                <Button Content="⬆" ToolTip="上移"
                                        Command="{Binding EditorViewModel.MoveUpCommand}"
                                        Padding="8,2" Margin="2,0" FontSize="12"/>
                                <Button Content="⬇" ToolTip="下移"
                                        Command="{Binding EditorViewModel.MoveDownCommand}"
                                        Padding="8,2" Margin="2,0" FontSize="12"/>
                                <Button Content="🗑️" ToolTip="刪除 (Delete)"
                                        Command="{Binding EditorViewModel.DeleteActionCommand}"
                                        Padding="8,2" Margin="2,0" FontSize="12"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="3" Width="5" HorizontalAlignment="Stretch"/>

            <!-- Right Panel: Properties + Variables Tabs -->
            <Border Grid.Column="4" BorderBrush="#E0E0E0" BorderThickness="1,0,0,0">
                <TabControl BorderThickness="0" Background="White">
                    <TabItem>
                        <TabItem.Header>
                            <TextBlock Text="🔧 屬性" FontSize="12"/>
                        </TabItem.Header>
                        <local:PropertiesPanel DataContext="{Binding PropertiesViewModel}"/>
                    </TabItem>
                    <TabItem>
                        <TabItem.Header>
                            <TextBlock Text="📦 變數" FontSize="12"/>
                        </TabItem.Header>
                        <local:VariablesPanel DataContext="{Binding VariablesViewModel}"/>
                    </TabItem>
                    <TabItem Visibility="Collapsed">
                        <TabItem.Header>
                            <TextBlock Text="⚙️ 設定" FontSize="12"/>
                        </TabItem.Header>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="10">
                                <TextBlock Text="螢幕設定 (手動)" FontWeight="Bold" Margin="0,0,0,5"/>
                                <TextBlock Text="若指令執行座標不正確，請手動設定。" FontSize="11" Foreground="#666" TextWrapping="Wrap" Margin="0,0,0,10"/>
                                
                                <TextBlock Text="寬度 (Pixels):"/>
                                <TextBox Text="{Binding ScreenWidth, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,5"/>
                                
                                <TextBlock Text="高度 (Pixels):"/>
                                <TextBox Text="{Binding ScreenHeight, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,5"/>
                                
                                <TextBlock Text="縮放比例 (%):"/>
                                <TextBox Text="{Binding ScreenScale, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,5"/>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>
                </TabControl>
            </Border>
        </Grid>

        <!-- Execution Log Panel -->
        <Expander Grid.Row="3" Header="📋 執行日誌" IsExpanded="{Binding IsLogPanelExpanded}" 
                  BorderBrush="#CCCCCC" BorderThickness="0,1,0,0">
            <Grid Height="150">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <!-- Log Toolbar -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="5,3">
                    <TextBlock Text="{Binding ExecutionStatusText}" VerticalAlignment="Center" 
                               FontWeight="SemiBold" Foreground="#555"/>
                    <Button Content="清除" Command="{Binding ClearLogsCommand}" 
                            Margin="15,0,0,0" Padding="8,2" FontSize="11"/>
                    <Button Content="匯出" Command="{Binding ExportLogsCommand}" 
                            Margin="5,0,0,0" Padding="8,2" FontSize="11" ToolTip="將日誌匯出為 TXT 檔"/>
                </StackPanel>
                
                <!-- Log List -->
                <ListBox Grid.Row="1" ItemsSource="{Binding ExecutionLogs}" 
                         x:Name="LogListBox"
                         FontFamily="Consolas" FontSize="12"
                         Background="#1E1E1E" Foreground="#DCDCDC"
                         BorderThickness="0" Padding="5"
                         ScrollViewer.CanContentScroll="True"
                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" Padding="2,1" TextWrapping="NoWrap"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Expander>

        <!-- Status Bar -->
        <StatusBar Grid.Row="4">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusMessage}"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem HorizontalAlignment="Right">
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="8" Height="8" Margin="0,0,5,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="#28A745"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                        <Setter Property="Fill" Value="#FFC107"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock>
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="就緒"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                        <Setter Property="Text" Value="執行中"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
