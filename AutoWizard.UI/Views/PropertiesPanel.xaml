<UserControl x:Class="AutoWizard.UI.Views.PropertiesPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="250">
    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#FAFAFA" Padding="10,8" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
            <StackPanel>
                <TextBlock Text="⚙ 屬性面板" FontWeight="Bold" FontSize="13"/>
                <TextBlock Text="{Binding ItemType}" Foreground="#757575" FontSize="11" Margin="0,3,0,0"/>
            </StackPanel>
        </Border>

        <!-- Properties List -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Properties}" Padding="4">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <!-- 使用 ContentControl 根據 IsButton/IsSeparator 切換樣式 -->
                        <ContentControl Content="{Binding}">
                            <ContentControl.Resources>
                                <!-- 預設模板：Key-Value 屬性列 -->
                                <DataTemplate x:Key="PropertyTemplate">
                                    <Border Padding="8,5" BorderBrush="#F0F0F0" BorderThickness="0,0,0,1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="90"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0" Text="{Binding Key}" 
                                                       FontSize="11" Foreground="#616161" 
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"
                                                       ToolTip="{Binding Key}"/>

                                            <ContentControl Grid.Column="1" Content="{Binding}">
                                                <ContentControl.Resources>
                                                    <DataTemplate x:Key="TextTemplate">
                                                        <TextBox Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                 Padding="4,3" BorderBrush="#E0E0E0" BorderThickness="1"
                                                                 FontSize="11" VerticalAlignment="Center"/>
                                                    </DataTemplate>
                                                    <DataTemplate x:Key="BoolTemplate">
                                                        <ComboBox SelectedValue="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                  SelectedValuePath="Content"
                                                                  Padding="4,3" BorderBrush="#E0E0E0" BorderThickness="1"
                                                                  FontSize="11" VerticalAlignment="Center">
                                                            <ComboBoxItem Content="True"/>
                                                            <ComboBoxItem Content="False"/>
                                                        </ComboBox>
                                                    </DataTemplate>
                                                    <DataTemplate x:Key="EnumTemplate">
                                                        <ComboBox ItemsSource="{Binding EnumValues}"
                                                                  SelectedValue="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                  Padding="4,3" BorderBrush="#E0E0E0" BorderThickness="1"
                                                                  FontSize="11" VerticalAlignment="Center" />
                                                    </DataTemplate>
                                                </ContentControl.Resources>
                                                <ContentControl.Style>
                                                    <Style TargetType="ContentControl">
                                                        <Setter Property="ContentTemplate" Value="{StaticResource TextTemplate}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding PropertyType.Name}" Value="Boolean">
                                                                <Setter Property="ContentTemplate" Value="{StaticResource BoolTemplate}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsEnum}" Value="True">
                                                                <Setter Property="ContentTemplate" Value="{StaticResource EnumTemplate}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </ContentControl.Style>
                                            </ContentControl>
                                        </Grid>
                                    </Border>
                                </DataTemplate>

                                <!-- 按鈕模板 -->
                                <DataTemplate x:Key="ButtonTemplate">
                                    <Border Padding="4,3" Margin="4,2">
                                        <Button Content="{Binding Key}" 
                                                Command="{Binding ButtonCommand}"
                                                Padding="8,4" FontSize="11"
                                                Background="#F5F5F5" BorderBrush="#E0E0E0"
                                                Cursor="Hand"
                                                HorizontalAlignment="Stretch"/>
                                    </Border>
                                </DataTemplate>

                                <!-- 分隔線模板 -->
                                <DataTemplate x:Key="SeparatorTemplate">
                                    <Border Padding="4,6" Background="#FAFAFA" Margin="0,4,0,0"
                                            BorderBrush="#E0E0E0" BorderThickness="0,1,0,0">
                                        <TextBlock Text="{Binding Key}" 
                                                   FontSize="11" FontWeight="SemiBold"
                                                   Foreground="#FF9800" 
                                                   HorizontalAlignment="Center"/>
                                    </Border>
                                </DataTemplate>
                            </ContentControl.Resources>

                            <ContentControl.Style>
                                <Style TargetType="ContentControl">
                                    <Setter Property="ContentTemplate" Value="{StaticResource PropertyTemplate}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsButton}" Value="True">
                                            <Setter Property="ContentTemplate" Value="{StaticResource ButtonTemplate}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsSeparator}" Value="True">
                                            <Setter Property="ContentTemplate" Value="{StaticResource SeparatorTemplate}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ContentControl.Style>
                        </ContentControl>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Empty State -->
        <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center"
                    Margin="10">
            <StackPanel.Style>
                <Style TargetType="StackPanel">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ItemType}" Value="未選擇">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </StackPanel.Style>
            <TextBlock Text="⚙" FontSize="28" HorizontalAlignment="Center" Foreground="#E0E0E0" Margin="0,0,0,8"/>
            <TextBlock Text="未選擇任何指令" Foreground="#BDBDBD" FontSize="12" TextAlignment="Center"/>
            <TextBlock Text="點擊編輯器中的指令塊&#x0a;即可在此檢視屬性" 
                       Foreground="#E0E0E0" FontSize="10" 
                       TextAlignment="Center" Margin="0,5,0,0" TextWrapping="Wrap"/>
        </StackPanel>
    </Grid>
</UserControl>
