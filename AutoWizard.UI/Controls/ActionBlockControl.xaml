<UserControl x:Class="AutoWizard.UI.Controls.ActionBlockControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:AutoWizard.UI.Controls"
             xmlns:vm="clr-namespace:AutoWizard.UI.ViewModels"
             mc:Ignorable="d"
             d:DesignHeight="52" d:DesignWidth="600">
    <UserControl.Resources>
        <!-- Converters -->
        <local:LeftIndentConverter x:Key="LeftIndentConverter"/>
        <local:NodeTypeToVisibilityConverter x:Key="NodeTypeToVisConverter"/>
        <local:ActionToColorConverter x:Key="ActionToColorConverter"/>
        <local:ActionToIconConverter x:Key="ActionToIconConverter"/>
        <local:ActionToTypeNameConverter x:Key="ActionToTypeNameConverter"/>
        <local:ActionToSummaryConverter x:Key="ActionToSummaryConverter"/>
        <local:ActionToContainerBadgeConverter x:Key="ActionToContainerBadgeConverter"/>
        <local:BoolToOpacityConverter x:Key="BoolToOpacityConverter"/>

        <Style x:Key="ActionBlockBorder" TargetType="Border">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect ShadowDepth="1" BlurRadius="4" Opacity="0.12" Color="#000000"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="#90CAF9"/>
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect ShadowDepth="1" BlurRadius="6" Opacity="0.2" Color="#2196F3"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
                <!-- 執行中高亮特效 -->
                <DataTrigger Binding="{Binding IsExecuting}" Value="True">
                    <Setter Property="BorderBrush" Value="#FFA000"/>
                    <Setter Property="BorderThickness" Value="2"/>
                    <Setter Property="Background" Value="#FFF8E1"/>
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect ShadowDepth="2" BlurRadius="8" Opacity="0.3" Color="#FFA000"/>
                        </Setter.Value>
                    </Setter>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <!-- 根據 NodeType 切換顯示 -->
    <Grid Margin="{Binding LeftIndent, Converter={StaticResource LeftIndentConverter}, FallbackValue='0,0,0,0'}">
        
        <!-- === 指令節點 (NodeType.Action) === -->
        <Border Style="{StaticResource ActionBlockBorder}"
                Opacity="{Binding IsCut, Converter={StaticResource BoolToOpacityConverter}}"
                Visibility="{Binding NodeType, Converter={StaticResource NodeTypeToVisConverter}, ConverterParameter=Action}">
            <Grid Height="44">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="6"/>
                    <ColumnDefinition Width="36"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 左側色帶 -->
                <Border Grid.Column="0" CornerRadius="6,0,0,6"
                        Background="{Binding Action, RelativeSource={RelativeSource AncestorType=UserControl}, 
                                     Converter={StaticResource ActionToColorConverter}}"/>

                <!-- 圖示 -->
                <TextBlock Grid.Column="1" 
                           Text="{Binding Action, RelativeSource={RelativeSource AncestorType=UserControl}, 
                                  Converter={StaticResource ActionToIconConverter}}"
                           FontSize="18" VerticalAlignment="Center" HorizontalAlignment="Center"/>

                <!-- 指令名稱 + 類型 -->
                <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="6,0,0,0">
                    <TextBlock Text="{Binding Action.Name}" FontWeight="SemiBold" FontSize="13"
                               Foreground="#212121"/>
                    <TextBlock Text="{Binding Action, RelativeSource={RelativeSource AncestorType=UserControl},
                                     Converter={StaticResource ActionToTypeNameConverter}}"
                               FontSize="10" Foreground="#757575"/>
                </StackPanel>

                <!-- 參數摘要 -->
                <TextBlock Grid.Column="3" 
                           Text="{Binding Action, RelativeSource={RelativeSource AncestorType=UserControl},
                                  Converter={StaticResource ActionToSummaryConverter}}"
                           FontSize="11" Foreground="#9E9E9E" VerticalAlignment="Center"
                           Margin="12,0" TextTrimming="CharacterEllipsis"/>

                <!-- 啟用/停用指示 -->
                <Ellipse Grid.Column="4" Width="8" Height="8" Margin="4,0"
                         VerticalAlignment="Center">
                    <Ellipse.Style>
                        <Style TargetType="Ellipse">
                            <Setter Property="Fill" Value="#4CAF50"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Action.IsEnabled}" Value="False">
                                    <Setter Property="Fill" Value="#BDBDBD"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Ellipse.Style>
                </Ellipse>

                <!-- 容器標記 -->
                <TextBlock Grid.Column="5" 
                           Text="{Binding Action, RelativeSource={RelativeSource AncestorType=UserControl},
                                  Converter={StaticResource ActionToContainerBadgeConverter}}"
                           FontSize="9" Foreground="#BDBDBD" VerticalAlignment="Center"
                           Margin="4,0,10,0"/>
            </Grid>
        </Border>

        <!-- === 段落標題 (NodeType.SectionHeader) === -->
        <Border Visibility="{Binding NodeType, Converter={StaticResource NodeTypeToVisConverter}, ConverterParameter=SectionHeader}"
                Margin="0,4,0,2" Padding="8,3">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <!-- 虛線 + 標題 -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="20" Height="1" Background="#E0E0E0" Margin="0,0,6,0" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding SectionLabel}" FontSize="11" Foreground="#9E9E9E" 
                               FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <Border Height="1" Background="#E0E0E0" Margin="6,0,0,0" VerticalAlignment="Center"
                            HorizontalAlignment="Stretch" MinWidth="40"/>
                </StackPanel>
                
                <!-- 子指令數量提示 (如有) -->
                <TextBlock Grid.Column="1" FontSize="9" Foreground="#BDBDBD" VerticalAlignment="Center"
                           Margin="4,0,0,0"/>
            </Grid>
        </Border>

        <!-- === 容器結尾 (NodeType.ContainerEnd) === -->
        <Border Visibility="{Binding NodeType, Converter={StaticResource NodeTypeToVisConverter}, ConverterParameter=ContainerEnd}"
                Margin="0,0,0,4" Padding="8,1">
            <StackPanel Orientation="Horizontal">
                <Border Width="30" Height="1" Background="#E0E0E0" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding SectionLabel}" FontSize="9" Foreground="#BDBDBD" 
                           FontStyle="Italic" Margin="6,0" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
