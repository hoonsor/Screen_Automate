[
    {
        "$type": "SetVariable",
        "Id": "init-001",
        "Name": "初始化變數",
        "Description": "確保 foundTarget_Confidence 變數存在，避免條件判斷錯誤",
        "IsEnabled": true,
        "VariableName": "foundTarget_Confidence",
        "ValueExpression": "0"
    },
    {
        "$type": "FindImage",
        "Id": "test-001",
        "Name": "尋找紅色方塊",
        "Description": "測試尋找 Images/sample_target.png",
        "IsEnabled": true,
        "ErrorPolicy": {
            "RetryCount": 3,
            "RetryIntervalMs": 1000,
            "ContinueOnError": true
        },
        "DelayBeforeMs": 1000,
        "DelayAfterMs": 0,
        "TemplateImagePath": "Images/sample_target.png",
        "Threshold": 0.8,
        "TimeoutMs": 5000,
        "IntervalMs": 500,
        "ClickWhenFound": true,
        "SaveToVariable": "foundTarget"
    },
    {
        "$type": "If",
        "Id": "test-002",
        "Name": "檢查結果",
        "Description": "如果 foundTarget_Confidence > 0 則表示成功",
        "IsEnabled": true,
        "ConditionType": "Expression",
        "ConditionExpression": "{foundTarget_Confidence} > 0",
        "ThenActions": [
            {
                "$type": "Type",
                "Id": "success",
                "Name": "成功訊息",
                "IsEnabled": true,
                "Text": "Success! Image found at ({foundTarget_X}, {foundTarget_Y}) with confidence {foundTarget_Confidence}",
                "Mode": "Simulate"
            }
        ],
        "ElseActions": [
            {
                "$type": "Type",
                "Id": "fail",
                "Name": "失敗訊息",
                "IsEnabled": true,
                "Text": "Failed to find image.",
                "Mode": "Simulate"
            }
        ]
    }
]
