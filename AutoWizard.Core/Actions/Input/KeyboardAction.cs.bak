            try
            {
                // ... (commented out code)
            }
            catch (Exception ex)
            {
                return new ActionResult
                {
                    Success = false,
                    Message = $"Keyboard action failed: {ex.Message}",
                    Exception = ex
                };
            }
            */
        }

        /// <summary>
        /// 取得所有支援的按鍵名稱
        /// </summary>
        public static IEnumerable<string> GetSupportedKeys() => VirtualKeys.Keys;
    }
}
